                "public_key": {
                    "type": "string"
                },
                "signature": {
                    "type": "string"
                },
                "summary": {
                    "type": "string",
                    "maxLength": 200
                },
                "tags": {
                    "type": "array",
                    "maxItems": 20,
                    "items": {
                        "type": "string"
                    }
                }
            }
        },

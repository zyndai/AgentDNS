                },
                "local_agents": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "node_type": {
                    "description": "full, light, gateway",
                    "type": "string"
                },
                "peer_count": {
                    "type": "integer"
                },
                "registry_id": {
                    "type": "string"
                },
                "uptime": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "github_com_agentdns_agent-dns_internal_models.PeerInfo": {

                },
                "enrich": {
                    "type": "boolean"
                },
                "federated": {
                    "type": "boolean"
                },
                "max_results": {
                    "type": "integer"
                },
                "min_trust_score": {
                    "type": "number"
                },
                "query": {
                    "type": "string"
                },
                "status": {
                    "description": "online, offline, any",
                    "type": "string"
                },
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "timeout_ms": {
                    "type": "integer"
                }
